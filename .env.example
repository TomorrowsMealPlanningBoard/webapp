# Vertex AI (Google Cloud) の設定
# gcloud auth application-default login で認証済みであること
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Gemini モデル・ロケーション（用途別に個別設定可能）
# テキスト生成（レシピ提案・ソース抽出）
# GEMINI_TEXT_MODEL=gemini-3.1-flash-lite
# GEMINI_TEXT_LOCATION=global

# 画像解析（冷蔵庫写真からの食材認識）
# GEMINI_VISION_MODEL=gemini-3.1-flash-lite
# GEMINI_VISION_LOCATION=global

# Live API（調理中の音声アシスタント）
# GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
# GEMINI_LIVE_LOCATION=us-central1   # Live API は global 未対応（2026-07時点）

# JWT署名鍵（必須）: 本番は Secret Manager で管理。ローカル開発用に任意の値を設定すること
# JWT_SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">

# Google OAuth クライアントID（Issue #90）: 設定するとログイン画面に「Googleでログイン」ボタンが表示される
# Google Cloud Console → APIとサービス → 認証情報 → OAuthクライアントID で取得
# GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
